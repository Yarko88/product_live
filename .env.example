# Backend (опционально; по умолчанию используются значения из docker-compose)
# DATABASE_URL=postgresql://postgres:postgres@db:5432/live_city
# CORS_ORIGINS=["*"]  # или JSON-массив: ["http://158.160.6.2:3000","http://localhost:3000"]
# JWT_SECRET_KEY=CHANGE_ME_SECRET
# JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
#
# После первого запуска выполни: docker compose exec backend python -m app.cli_init_db
# Будет создан тестовый пользователь: user@live.city / password123

# Frontend (для доступа к API не с localhost)
# NEXT_PUBLIC_API_URL=http://your-backend-host:8000
